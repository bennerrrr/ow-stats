# Comma-separated list of battletags to track on first startup
# Example: TRACKED_PLAYERS=Ben#1234,Alice#5678,Bob#9999
TRACKED_PLAYERS=banjoe#11390

# Path to the SQLite database file
DATABASE_URL=sqlite+aiosqlite:///./data/ow_stats.db

# How often to poll for new stats (minutes)
POLL_INTERVAL_MINUTES=30

# Discord bot token (from https://discord.com/developers/applications)
# Leave blank to disable the Discord bot
DISCORD_BOT_TOKEN=
