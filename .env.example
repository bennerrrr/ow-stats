# Comma-separated list of battletags to track on first startup
# Example: TRACKED_PLAYERS=Ben#1234,Alice#5678,Bob#9999
TRACKED_PLAYERS=

# Path to the SQLite database file
DATABASE_URL=sqlite+aiosqlite:///./data/ow_stats.db

# How often to poll for new stats (minutes)
POLL_INTERVAL_MINUTES=30

# IANA timezone for timestamps in the web UI (e.g. America/New_York, Europe/London)
DISPLAY_TIMEZONE=America/New_York

# Steam Web API key — required for Hell Let Loose players (free at steamcommunity.com/dev/apikey)
STEAM_API_KEY=

# Discord bot token (from https://discord.com/developers/applications)
# Leave blank to disable the Discord bot
DISCORD_BOT_TOKEN=

# Secret token for the /utils admin panel and API endpoints
# Required to use the utility page — choose any strong random string
UTILS_TOKEN=
